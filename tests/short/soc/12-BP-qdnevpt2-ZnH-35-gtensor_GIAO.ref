import unittest
import numpy as np
import math
import pyscf.gto
import pyscf.scf
import pyscf.mcscf
import prism.interface
import prism.nevpt

np.set_printoptions(suppress=True)

mol = pyscf.gto.Mole()
mol.atom = [['Zn', (0.0, 0.0, 0.0)],
            ['H', (0.0,  0,  1.595 )]
            ]
mol.basis = 'def2-tzvp'
mol.symmetry = False
mol.spin = 1
mol.verbose = 4
mol.build()


# RDFT calculation
mf = pyscf.scf.RKS(mol).x2c()
mf.xc = "bp86"
ehf = mf.scf()
mf.analyze()

# SA-CASSCF calculation
n_states = 4
weights = np.ones(n_states)/n_states
mc = pyscf.mcscf.CASSCF(mf, 5, 3).state_average_(weights)
mc.conv_tol = 1e-11
mc.conv_tol_grad = 1e-6
emc = mc.mc1step()[0]
mc.analyze()


# QD-NEVPT2 with all electrons correlated
interface = prism.interface.PYSCF(mf, mc, opt_einsum = True)
nevpt = prism.nevpt.QDNEVPT(interface)
nevpt.compute_singles_amplitudes = False
nevpt.semi_internal_projector = "gno"
nevpt.s_thresh_singles = 1e-8
nevpt.s_thresh_doubles = 1e-8
nevpt.method = "nevpt2"
nevpt.soc = "Breit-Pauli" # Possible methods: Breit-Pauli (BP), DKH1 (x2c-1)
nevpt.verbose = 4
nevpt.gtensor = True
nevpt.gtensor_target_state = 1
nevpt.gtensor_origin_type = 'GIAO' 
e_tot, e_corr, osc = nevpt.kernel()
exit()

class KnownValues(unittest.TestCase):

    def test_pyscf(self):
        self.assertAlmostEqual(mc.e_tot,   -1791.44304512656, 6)
        self.assertAlmostEqual(mc.e_cas,  -2.02048893196252, 6)

    def test_prism(self):

        e_tot, e_corr, osc = nevpt.kernel()

        #Prism
        self.assertAlmostEqual(e_tot[0], -1792.202766317766 , 5)
        self.assertAlmostEqual(e_tot[1], -1792.202766317766 , 5)
        self.assertAlmostEqual(e_tot[2], -1792.099589949298 , 5)
        self.assertAlmostEqual(e_tot[3], -1792.099589949296 , 5)
        self.assertAlmostEqual(e_tot[4], -1792.098209192667 , 5)
        self.assertAlmostEqual(e_tot[5], -1792.098209192666 , 5)
        self.assertAlmostEqual(e_tot[6], -1792.033455602741 , 5)
        self.assertAlmostEqual(e_tot[7], -1792.033455602741 , 5)

        self.assertAlmostEqual(osc[0], 0.0, 5)
        self.assertAlmostEqual(osc[1],  0.05283955, 5)
        self.assertAlmostEqual(osc[2],  0.05283955, 5)
        self.assertAlmostEqual(osc[3],  0.05354203, 5)
        self.assertAlmostEqual(osc[4],  0.05354203, 5)
        self.assertAlmostEqual(osc[5],  0.05010837, 5)
        self.assertAlmostEqual(osc[6],  0.05010837, 5)

        self.assertAlmostEqual(nevpt.g_factor[0], 2.002301, 5)
        self.assertAlmostEqual(nevpt.g_factor[1], 2.006063, 5)
        self.assertAlmostEqual(nevpt.g_factor[2], 2.006063, 5)






if __name__ == "__main__":
    print("SOC-QD-NEVPT2 test")
    unittest.main()

