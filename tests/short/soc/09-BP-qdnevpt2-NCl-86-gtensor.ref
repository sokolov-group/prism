import unittest
import numpy as np
import math
import pyscf.gto
import pyscf.scf
import pyscf.mcscf
import prism.interface
import prism.nevpt

np.set_printoptions(suppress=True)

mol = pyscf.gto.Mole()
mol.atom =[ 
[ 'N',  (0, 0, 0)],
[ 'Cl',  ( 0, 0, 1.643)] 
]
mol.basis = 'def2-tzvp'
mol.symmetry = False
mol.spin = 2
mol.verbose = 4
mol.build()


# RDFT calculation
mf = pyscf.scf.RKS(mol).x2c()
mf.xc = "bp86"
ehf = mf.scf()
mf.analyze()

# SA-CASSCF calculation
n_states = 9
weights = np.ones(n_states)/n_states
mc = pyscf.mcscf.CASSCF(mf, 6, 8).state_average_(weights)
mc.conv_tol = 1e-11
mc.conv_tol_grad = 1e-6
emc = mc.mc1step()[0]
mc.analyze()


# QD-NEVPT2 with all electrons correlated
interface = prism.interface.PYSCF(mf, mc, opt_einsum = True)
nevpt = prism.nevpt.NEVPT(interface)
nevpt.compute_singles_amplitudes = False
nevpt.semi_internal_projector = "gno"
nevpt.s_thresh_singles = 1e-8
nevpt.s_thresh_doubles = 1e-8
nevpt.method = "qd-nevpt2"
nevpt.soc = "Breit-Pauli" # Possible methods: Breit-Pauli (BP), DKH1 (x2c-1)
nevpt.verbose = 4
nevpt.gtensor = True
nevpt.origin_type = 'charge' 
e_tot, e_corr, osc = nevpt.kernel()

class KnownValues(unittest.TestCase):

    def test_pyscf(self):
        self.assertAlmostEqual(mc.e_tot,  -514.996350232067, 6)
        self.assertAlmostEqual(mc.e_cas,  -15.3800081255993, 6)

    def test_prism(self):

        e_tot, e_corr, osc = nevpt.kernel()

        self.assertAlmostEqual(e_tot[0],    -515.619766868835 , 5)
        self.assertAlmostEqual(e_tot[1],    -515.619766533567 , 5)
        self.assertAlmostEqual(e_tot[2],    -515.619766533566 , 5)
        self.assertAlmostEqual(e_tot[3],    -515.429556192775 , 5)
        self.assertAlmostEqual(e_tot[4],    -515.429552658250 , 5)
        self.assertAlmostEqual(e_tot[5],    -515.429015984957 , 5)
        self.assertAlmostEqual(e_tot[6],    -515.429015984953 , 5)
        self.assertAlmostEqual(e_tot[7],    -515.428482321945 , 5)
