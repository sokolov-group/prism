        self.assertAlmostEqual(nevpt.g_factor[0], 2.002306, 5)
        self.assertAlmostEqual(nevpt.g_factor[1], 2.007136, 5)
        self.assertAlmostEqual(nevpt.g_factor[2], 2.007136, 5)

if __name__ == "__main__":
    print("SOC-QD-NEVPT2 test")
    unittest.main()

    

